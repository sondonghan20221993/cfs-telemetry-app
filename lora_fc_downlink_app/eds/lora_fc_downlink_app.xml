<?xml version="1.0" encoding="UTF-8"?>
<PackageFile xmlns="http://www.ccsds.org/schema/sois/seds">
  <Package name="TELEMETRY_APP" shortDescription="Telemetry Application Package">
    <DataTypeSet>
      <ContainerDataType name="HkTlm_Payload" shortDescription="Telemetry App housekeeping content">
        <EntryList>
          <Entry name="CommandErrorCounter" type="BASE_TYPES/uint8" />
          <Entry name="CommandCounter" type="BASE_TYPES/uint8" />
          <Entry name="LinkState" type="BASE_TYPES/uint8" />
          <Entry name="ActiveTransportId" type="BASE_TYPES/uint8" />
          <Entry name="LastUpdateAgeMs" type="BASE_TYPES/uint32" />
          <Entry name="NominalTimeoutMs" type="BASE_TYPES/uint32" />
          <Entry name="DegradedTimeoutMs" type="BASE_TYPES/uint32" />
          <Entry name="LostTimeoutMs" type="BASE_TYPES/uint32" />
          <Entry name="DegradedTransitionCount" type="BASE_TYPES/uint32" />
          <Entry name="LostTransitionCount" type="BASE_TYPES/uint32" />
          <Entry name="RecoveryCount" type="BASE_TYPES/uint32" />
        </EntryList>
      </ContainerDataType>

      <ContainerDataType name="StatusTlm_Payload" shortDescription="Telemetry link status content">
        <EntryList>
          <Entry name="LinkState" type="BASE_TYPES/uint8" />
          <Entry name="ActiveTransportId" type="BASE_TYPES/uint8" />
          <Entry name="Reserved" type="BASE_TYPES/uint16" />
          <Entry name="LastUpdateAgeMs" type="BASE_TYPES/uint32" />
          <Entry name="DegradedTransitionCount" type="BASE_TYPES/uint32" />
          <Entry name="LostTransitionCount" type="BASE_TYPES/uint32" />
          <Entry name="RecoveryCount" type="BASE_TYPES/uint32" />
        </EntryList>
      </ContainerDataType>

      <ContainerDataType name="MonitorTlm_Payload" shortDescription="Telemetry monitor input">
        <EntryList>
          <Entry name="ActiveTransportId" type="BASE_TYPES/uint8" />
          <Entry name="Valid" type="BASE_TYPES/uint8" />
          <Entry name="Reserved" type="BASE_TYPES/uint16" />
          <Entry name="UpdateAgeMs" type="BASE_TYPES/uint32" />
        </EntryList>
      </ContainerDataType>

      <ContainerDataType name="SendHkCmd" baseType="CFE_HDR/CommandHeader" />
      <ContainerDataType name="CommandBase" baseType="CFE_HDR/CommandHeader" />

      <ContainerDataType name="HkTlm" baseType="CFE_HDR/TelemetryHeader">
        <EntryList>
          <Entry type="HkTlm_Payload" name="Payload" />
        </EntryList>
      </ContainerDataType>

      <ContainerDataType name="StatusTlm" baseType="CFE_HDR/TelemetryHeader">
        <EntryList>
          <Entry type="StatusTlm_Payload" name="Payload" />
        </EntryList>
      </ContainerDataType>

      <ContainerDataType name="MonitorTlm" baseType="CFE_HDR/TelemetryHeader">
        <EntryList>
          <Entry type="MonitorTlm_Payload" name="Payload" />
        </EntryList>
      </ContainerDataType>

      <ContainerDataType name="NoopCmd" baseType="CommandBase">
        <ConstraintSet>
          <ValueConstraint entry="Sec.FunctionCode" value="0" />
        </ConstraintSet>
      </ContainerDataType>

      <ContainerDataType name="ResetCountersCmd" baseType="CommandBase">
        <ConstraintSet>
          <ValueConstraint entry="Sec.FunctionCode" value="1" />
        </ConstraintSet>
      </ContainerDataType>
    </DataTypeSet>

    <ComponentSet>
      <Component name="Application">
        <RequiredInterfaceSet>
          <Interface name="CMD" shortDescription="Software bus telecommand interface" type="CFE_SB/Telecommand">
            <GenericTypeMapSet>
              <GenericTypeMap name="TelecommandDataType" type="CommandBase" />
            </GenericTypeMapSet>
          </Interface>
          <Interface name="SEND_HK" shortDescription="Send telemetry command interface" type="CFE_SB/Telecommand">
            <GenericTypeMapSet>
              <GenericTypeMap name="TelecommandDataType" type="SendHkCmd" />
            </GenericTypeMapSet>
          </Interface>
          <Interface name="HK_TLM" shortDescription="Software bus housekeeping telemetry interface" type="CFE_SB/Telemetry">
            <GenericTypeMapSet>
              <GenericTypeMap name="TelemetryDataType" type="HkTlm" />
            </GenericTypeMapSet>
          </Interface>
          <Interface name="MONITOR" shortDescription="Telemetry monitor input interface" type="CFE_SB/Telemetry">
            <GenericTypeMapSet>
              <GenericTypeMap name="TelemetryDataType" type="MonitorTlm" />
            </GenericTypeMapSet>
          </Interface>
          <Interface name="STATUS" shortDescription="Telemetry link status output interface" type="CFE_SB/Telemetry">
            <GenericTypeMapSet>
              <GenericTypeMap name="TelemetryDataType" type="StatusTlm" />
            </GenericTypeMapSet>
          </Interface>
        </RequiredInterfaceSet>
        <Implementation>
          <VariableSet>
            <Variable type="BASE_TYPES/uint16" readOnly="true" name="CmdTopicId" initialValue="${CFE_MISSION/TELEMETRY_APP_CMD_TOPICID}" />
            <Variable type="BASE_TYPES/uint16" readOnly="true" name="SendHkTopicId" initialValue="${CFE_MISSION/TELEMETRY_APP_SEND_HK_TOPICID}" />
            <Variable type="BASE_TYPES/uint16" readOnly="true" name="HkTlmTopicId" initialValue="${CFE_MISSION/TELEMETRY_APP_HK_TLM_TOPICID}" />
            <Variable type="BASE_TYPES/uint16" readOnly="true" name="MonitorTopicId" initialValue="${CFE_MISSION/TELEMETRY_APP_MONITOR_TOPICID}" />
            <Variable type="BASE_TYPES/uint16" readOnly="true" name="StatusTopicId" initialValue="${CFE_MISSION/TELEMETRY_APP_STATUS_TOPICID}" />
          </VariableSet>
          <ParameterMapSet>
            <ParameterMap interface="CMD" parameter="TopicId" variableRef="CmdTopicId" />
            <ParameterMap interface="SEND_HK" parameter="TopicId" variableRef="SendHkTopicId" />
            <ParameterMap interface="HK_TLM" parameter="TopicId" variableRef="HkTlmTopicId" />
            <ParameterMap interface="MONITOR" parameter="TopicId" variableRef="MonitorTopicId" />
            <ParameterMap interface="STATUS" parameter="TopicId" variableRef="StatusTopicId" />
          </ParameterMapSet>
        </Implementation>
      </Component>
    </ComponentSet>
  </Package>
</PackageFile>
